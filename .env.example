# Obligatorisk: SOS API-prenumerationsnyckel från api-portal.artdatabanken.se
# Sätt till "mock" för att använda exempeldata under utveckling
SOS_API_KEY=din-nyckel-här

# Sidans namn och beskrivning
SITE_NAME=Fåglar vid Jordhammarsviken
SITE_DESCRIPTION=Senaste fågelobservationer vid Jordhammarsviken, Stenungsund

# Plats: koordinater (latitud, longitud) och radie i meter
SITE_LATITUDE=58.073
SITE_LONGITUDE=11.793
SITE_RADIUS_METERS=2000

# Antal dagar bakåt att visa (standard 7)
DAYS_BACK=7

# Cache-tid i sekunder (standard 300 = 5 minuter)
CACHE_TTL=300

# Flask-port (standard 5000)
FLASK_PORT=5000
